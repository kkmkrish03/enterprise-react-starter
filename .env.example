# =========================================================================
# Bodhika Enterprise Platform - Environment Configuration Template
# =========================================================================

# Database Connection Settings
# These settings are used for connecting the backend services to PostgreSQL.
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=password
DB_NAME=bodhika_enterprise

# Combined connection string for client integrations (e.g. Prisma, pg)
DATABASE_URL=postgresql://postgres:password@localhost:5432/bodhika_enterprise

# App settings
PORT=3000
NODE_ENV=development
VITE_AUTH_MODE=mock
